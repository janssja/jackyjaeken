# Mollie (get test key at https://my.mollie.com/dashboard/developers/api-keys)
MOLLIE_API_KEY=test_xxxxxxxxxxxx

# Site URL (the customer comes back here after Mollie)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public URL used for Mollie webhook. If empty, success page polls payment status.
# Set via `ngrok http 3000` when you want real webhook behaviour.
PUBLIC_WEBHOOK_URL=

# Sanity (create a free project at https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# SQLite file for orders (will be created automatically)
DATABASE_URL=./data/orders.db
